    "qa": {
      "appUrl": "https://opensource-demo.orangehrmlive.com/",
      "apiBaseUrl": "https://opensource-demo.orangehrmlive.com/web/index.php/",
      "credentialsEnvVar": "QA_APP_CREDENTIALS"
    }
  },
  "artifacts": {
    "rootDir": "qa-artifacts",
    "testPlanFile": "test-plan.md",
    "testCasesFile": "test-cases.md",
    "scriptChangesFile": "script-changes.md",
    "reportFile": "report.md",
    "jiraDraftsFile": "jira-bug-drafts.md"
