    "repoUrl": "",
    "tokenEnvVar": "GIT_TOKEN",
    "defaultBranchPrefix": "qa/"
  },
  "environments": {
    "dev": {
      "appUrl": "https://opensource-demo.orangehrmlive.com/",
      "apiBaseUrl": "https://opensource-demo.orangehrmlive.com/web/index.php/",
      "credentialsEnvVar": "DEV_APP_CREDENTIALS"
