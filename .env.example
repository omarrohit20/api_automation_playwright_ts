# Copy to .env and fill in real values. .env is git-ignored — never commit real tokens.

# Jira (Atlassian API token: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=

# Figma (personal access token: Figma > Settings > Personal access tokens)
FIGMA_API_TOKEN=

# Git provider token (repo read access for PR/branch context, if used)
GIT_TOKEN=

# App credentials per environment, as JSON: {"username":"...","password":"..."}
DEV_APP_CREDENTIALS=
QA_APP_CREDENTIALS=
